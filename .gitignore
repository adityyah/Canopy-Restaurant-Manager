# ==============================================================================
# .gitignore — Canopy Restaurant Manager
# ==============================================================================

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/
*.so

# ── Virtual Environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── SQLite Database ───────────────────────────────────────────────────────────
# The DB is generated locally by seed.py — never commit it.
*.db
*.sqlite3

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
dist/
.next/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Pytest / Coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/


images/